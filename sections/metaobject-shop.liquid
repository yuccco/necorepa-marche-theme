<section class="shop-detail">
  <div class="shop-detail-inner page-width">
    <div class="shop-detail-header">
      {%- if metaobject.shop_thumbnail.value != blank -%}
        <div class="shop-detail-thumbnail">
          <img
            src="{{ metaobject.shop_thumbnail.value | image_url: width: 800 }}"
            alt="{{ metaobject.shop_name.value }}"
            width="800"
            loading="lazy"
          >
        </div>
      {%- endif -%}

      <div class="shop-detail-info">
        {%- if metaobject.shop_icon.value != blank -%}
          <img
            src="{{ metaobject.shop_icon.value | image_url: width: 120 }}"
            alt=""
            class="shop-detail-icon"
            width="120"
            height="120"
          >
        {%- endif -%}

        <div class="shop-detail-info-right">
          <h1 class="shop-detail-name">{{ metaobject.shop_name.value }}</h1>

          <div class="shop-detail-links">
            {%- if metaobject.shop_hp.value != blank -%}
              <a href="{{ metaobject.shop_hp.value }}" target="_blank" rel="noopener" class="shop-detail-link shop-detail-link--hp">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </a>
            {%- endif -%}

            {%- if metaobject.shop_instagram.value != blank -%}
              <a href="{{ metaobject.shop_instagram.value }}" target="_blank" rel="noopener" class="shop-detail-link shop-detail-link--instagram">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
              </a>
            {%- endif -%}

            {%- if metaobject.shop_x.value != blank -%}
              <a href="{{ metaobject.shop_x.value }}" target="_blank" rel="noopener" class="shop-detail-link shop-detail-link--x">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            {%- endif -%}

            {%- if metaobject.shop_facebook.value != blank -%}
              <a href="{{ metaobject.shop_facebook.value }}" target="_blank" rel="noopener" class="shop-detail-link shop-detail-link--facebook">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>

    {%- if metaobject.shop_description.value != blank -%}
      <div class="shop-detail-description">
        {{ metaobject.shop_description.value }}
      </div>
    {%- endif -%}

    {%- assign shop_name = metaobject.shop_name.value -%}
    {%- assign shop_products = collections.all.products | where: 'vendor', shop_name -%}

    {%- if shop_products.size > 0 -%}
      <div class="shop-detail-products">
        <div class="page-headline-wrap">
          <svg class="section-headline-deco" viewBox="0 0 17.5 35" fill="none" aria-hidden="true">
            <path d="M 0 17.5 C 0 27.165 7.835 35 17.5 35 L 17.5 0 C 7.835 0 0 7.835 0 17.5 Z" fill="currentColor" fill-rule="nonzero" />
          </svg>
          <h2 class="shop-detail-products-title">{{ shop_name }}の商品</h2>
        </div>
        <div class="shop-detail-products-grid">
          {%- for product in shop_products limit: 12 -%}
            <a href="{{ product.url }}" class="shop-product-card">
              <div class="shop-product-image">
                {%- if product.featured_image != blank -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ product.title }}"
                    width="400"
                    loading="lazy"
                  >
                {%- endif -%}
              </div>
              <div class="shop-product-info">
                <p class="shop-product-title">{{ product.title }}</p>
                <p class="shop-product-price">{{ product.price | money }}</p>
              </div>
            </a>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <div class="shop-detail-back">
      <a href="/pages/shop-list" class="btn-back">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        ショップ一覧に戻る
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ショップ詳細",
  "settings": []
}
{% endschema %}
