<section class="shop-list-section">
  <div class="shop-list-inner">
    <div class="page-headline-wrap">
      <svg class="section-headline-deco" viewBox="0 0 17.5 35" fill="none" aria-hidden="true">
        <path d="M 0 17.5 C 0 27.165 7.835 35 17.5 35 L 17.5 0 C 7.835 0 0 7.835 0 17.5 Z" fill="currentColor" fill-rule="nonzero" />
      </svg>
      <h1 class="page-headline-title">ショップ一覧</h1>
    </div>
    <div class="shop-list-grid">
      {%- for shop in shop.metaobjects.shop.values -%}
        <a href="{{ shop.system.url }}" class="card-shop">
          <div class="card-shop-img-wrap">
            <div class="card-shop-img-inner">
              <div class="card-shop-photo">
                {%- if shop.shop_thumbnail.value != blank -%}
                  <img
                    src="{{ shop.shop_thumbnail.value | image_url: width: 360 }}"
                    alt="{{ shop.shop_name.value }}"
                    width="360"
                    height="240"
                    loading="lazy"
                    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"
                  >
                {%- elsif shop.shop_icon.value != blank -%}
                  <img
                    src="{{ shop.shop_icon.value | image_url: width: 360 }}"
                    alt="{{ shop.shop_name.value }}"
                    width="360"
                    height="240"
                    loading="lazy"
                    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"
                  >
                {%- endif -%}
              </div>
            </div>
          </div>
          <div class="card-shop-info">
            <p class="card-shop-name">{{ shop.shop_name.value }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
.shop-list-section {
  width: 100%;
  background: var(--cream);
  padding: 60px 0 80px;
}
.shop-list-inner {
  max-width: var(--content-max);
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  flex-direction: column;
  gap: 48px;
}
.shop-list-grid {
  display: grid;
  grid-template-columns: repeat(3, 360px);
  gap: 36px;
}
@media (max-width: 1023px) {
  .shop-list-grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
}
@media (max-width: 639px) {
  .shop-list-grid { grid-template-columns: 1fr; gap: 24px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "ショップ一覧"
}
{% endschema %}
