<section class="shop-section" id="shop" aria-label="ショップ一覧">
  <div class="shop-inner">
    <div class="section-headline-wrap">
      <div class="section-headline-left">
        <svg class="section-headline-deco" viewBox="0 0 17.5 35" fill="none" aria-hidden="true">
          <path d="M 0 17.5 C 0 27.165 7.835 35 17.5 35 L 17.5 0 C 7.835 0 0 7.835 0 17.5 Z" fill="currentColor" fill-rule="nonzero" />
        </svg>
        <h2 class="section-headline-text">{{ section.settings.title }}</h2>
      </div>
      <a href="/pages/shop-list" class="section-headline-link">
        一覧を見る <i class="fa-solid fa-angle-right"></i>
      </a>
    </div>

    <div class="carousel-wrapper">
      <button class="carousel-btn prev" id="shop-prev" aria-label="前のショップ">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M 9 2 L 4 7 L 9 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <div class="carousel-viewport">
        <div class="carousel-track" id="shop-carousel">
          {%- assign shop_count = 0 -%}
          {%- for shop_item in shop.metaobjects.shop.values -%}
            {%- assign shop_count = shop_count | plus: 1 -%}
            {%- if shop_count > section.settings.products_to_show -%}{%- break -%}{%- endif -%}
            <article class="card-shop">
              <div class="card-shop-img-wrap">
                <div class="card-shop-img-inner">
                  <a href="{{ shop_item.system.url }}" class="card-shop-photo" aria-label="{{ shop_item.shop_name.value }}">
                    {%- if shop_item.shop_thumbnail.value != blank -%}
                      <img
                        src="{{ shop_item.shop_thumbnail.value | image_url: width: 360 }}"
                        alt="{{ shop_item.shop_name.value }}"
                        width="360"
                        height="240"
                        loading="lazy"
                        style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"
                      >
                    {%- elsif shop_item.shop_icon.value != blank -%}
                      <img
                        src="{{ shop_item.shop_icon.value | image_url: width: 360 }}"
                        alt="{{ shop_item.shop_name.value }}"
                        width="360"
                        height="240"
                        loading="lazy"
                        style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"
                      >
                    {%- endif -%}
                  </a>
                </div>
              </div>
              <div class="card-shop-info">
                <p class="card-shop-name">{{ shop_item.shop_name.value }}</p>
              </div>
            </article>
          {%- else -%}
            <p style="color:var(--brick);padding:20px;">ショップが登録されていません。</p>
          {%- endfor -%}
        </div>
      </div>
      <button class="carousel-btn next" id="shop-next" aria-label="次のショップ">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M 5 2 L 10 7 L 5 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ネコリパ ショップ一覧",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "セクションタイトル",
      "default": "ショップ一覧"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "表示件数",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "ネコリパ ショップ一覧"
    }
  ]
}
{% endschema %}
