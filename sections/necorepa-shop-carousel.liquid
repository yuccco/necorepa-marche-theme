<section class="shop-section" id="shop" aria-label="ショップ一覧">
  <div class="shop-inner">
    <div class="section-headline-wrap">
      <div class="section-headline-left">
        <svg class="section-headline-deco" viewBox="0 0 17.5 35" fill="none" aria-hidden="true">
          <path d="M 0 17.5 C 0 27.165 7.835 35 17.5 35 L 17.5 0 C 7.835 0 0 7.835 0 17.5 Z" fill="currentColor" fill-rule="nonzero" />
        </svg>
        <h2 class="section-headline-text">{{ section.settings.title }}</h2>
      </div>
      <a href="{{ routes.collections_url }}" class="section-headline-link">
        一覧を見る <i class="fa-solid fa-angle-right"></i>
      </a>
    </div>

    <div class="carousel-wrapper">
      <button class="carousel-btn prev" id="shop-prev" aria-label="前のショップ">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M 9 2 L 4 7 L 9 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <div class="carousel-viewport">
        <div class="carousel-track" id="shop-carousel">
          {%- if section.settings.collection != blank -%}
            {%- assign shop_collection = collections[section.settings.collection] -%}
          {%- else -%}
            {%- assign shop_collection = collections.all -%}
          {%- endif -%}

          {%- assign shown_vendors = '' -%}
          {%- assign vendor_count = 0 -%}
          {%- for product in shop_collection.products limit: 50 -%}
            {%- unless shown_vendors contains product.vendor -%}
              {%- assign shown_vendors = shown_vendors | append: product.vendor | append: '|||' -%}
              {%- assign vendor_count = vendor_count | plus: 1 -%}
            <article class="card-shop">
              <div class="card-shop-img-wrap">
                <div class="card-shop-img-inner">
                  <a href="{{ product.url }}" class="card-shop-photo" aria-label="{{ product.title }}">
                    {%- if product.featured_image -%}
                      <img
                        src="{{ product.featured_image | image_url: width: 360 }}"
                        alt="{{ product.featured_image.alt | escape }}"
                        width="360"
                        height="240"
                        loading="lazy"
                        style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"
                      >
                    {%- endif -%}
                  </a>
                </div>
              </div>
              <div class="card-shop-info">
                <div class="card-shop-pill">
                  <div class="card-shop-pill-icons" aria-hidden="true">
                    <svg class="card-shop-pill-icon" viewBox="0 0 11 13" fill="none">
                      <path d="M 3.703 3.678 C 4.434 2.182 6.566 2.182 7.297 3.678 L 8.857 6.872 C 9.506 8.201 8.539 9.75 7.06 9.75 L 3.94 9.75 C 2.461 9.75 1.494 8.201 2.143 6.872 L 3.703 3.678 Z" fill="currentColor" fill-rule="nonzero" />
                    </svg>
                    <svg class="card-shop-pill-icon" viewBox="0 0 11 13" fill="none">
                      <path d="M 3.703 3.678 C 4.434 2.182 6.566 2.182 7.297 3.678 L 8.857 6.872 C 9.506 8.201 8.539 9.75 7.06 9.75 L 3.94 9.75 C 2.461 9.75 1.494 8.201 2.143 6.872 L 3.703 3.678 Z" fill="currentColor" fill-rule="nonzero" />
                    </svg>
                  </div>
                  <span class="card-shop-category">
                    {%- if product.type != blank -%}{{ product.type }}{%- else -%}ショップ{%- endif -%}
                  </span>
                </div>
                <p class="card-shop-name">{{ product.vendor | default: product.title }}</p>
              </div>
            </article>
            {%- if vendor_count >= section.settings.products_to_show -%}{%- break -%}{%- endif -%}
            {%- endunless -%}
          {%- else -%}
            <p style="color:var(--brick);padding:20px;">コレクションに商品がありません。</p>
          {%- endfor -%}
        </div>
      </div>
      <button class="carousel-btn next" id="shop-next" aria-label="次のショップ">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M 5 2 L 10 7 L 5 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ネコリパ ショップ一覧",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "セクションタイトル",
      "default": "ショップ一覧"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "表示するコレクション"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "表示件数",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "ネコリパ ショップ一覧"
    }
  ]
}
{% endschema %}
